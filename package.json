{
  "name": "payment-divider",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "db:boundary-check": "node scripts/check-sql-boundaries.mjs",
    "db:check": "corepack pnpm db:lint && corepack pnpm db:reset",
    "db:lint": "supabase db lint",
    "db:reset": "supabase db reset",
    "db:rls-test": "node scripts/run-rls-smoke-tests.mjs",
    "lint": "node -e \"console.log('Minimal lint placeholder: running package-level checks.')\" && corepack pnpm -r --if-present lint",
    "test": "corepack pnpm --filter @payment-divider/core test",
    "typecheck": "corepack pnpm -r --if-present typecheck"
  }
}
