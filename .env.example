# Copy to apps/mobile/.env to opt into the supabase-local data mode.
# Placeholders only — never commit real values. The public key is the
# publishable client key printed by `supabase start`; service/secret keys
# must never appear in any env file of this repo.

# App environment tier: "local" (default), "shared-alpha" or "production".
# Anything other than "local" hard-blocks the dev session (fixed local test
# credentials) — shared builds must use real Supabase auth. Fail-closed:
# unknown values are treated as production.
EXPO_PUBLIC_APP_ENV=local

# "local-demo" (default) or "supabase-local"
EXPO_PUBLIC_DATA_SOURCE=local-demo

# Local Supabase stack only (supabase start). No production/cloud URLs.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLIC_KEY=your-local-publishable-key
